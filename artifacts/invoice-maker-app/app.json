{
  "expo": {
    "name": "Invoice Maker",
    "slug": "invoice-maker-app",
    "owner": "pdanielyan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "invoice-maker-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5b5bd6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.paydan.invoicemaker"
    },
    "android": {
      "package": "com.paydan.invoicemaker",
      "minSdkVersion": 23,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "autolinking": {
      "exclude": [
        "@solana-mobile/mobile-wallet-adapter-protocol",
        "@solana-mobile/mobile-wallet-adapter-protocol-web",
        "@solana/wallet-adapter-base",
        "@solana/wallet-standard"
      ]
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "acc7a084-94d5-4c85-b4e3-77535d4122ac"
      }
    }
  }
}
